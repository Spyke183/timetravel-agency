# =====================================================================
#  TimeTravel Agency — Variables d'environnement
# =====================================================================
# Copiez ce fichier en ".env.local" et renseignez votre clé.
# Le chatbot fonctionne MÊME SANS clé (repli intelligent intégré),
# mais une clé active le vrai modèle de langage Mistral.
#
# Obtenir une clé gratuite : https://console.mistral.ai/  -> "API Keys"
# ---------------------------------------------------------------------

MISTRAL_API_KEY=

# (Optionnel) Modèle Mistral à utiliser. Par défaut : mistral-small-latest
# MISTRAL_MODEL=mistral-small-latest

# ---------------------------------------------------------------------
# Alternatives supportées automatiquement si MISTRAL_API_KEY est absent :
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# ---------------------------------------------------------------------
